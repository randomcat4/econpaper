{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://econpaper.local/schemas/citation_safety_report.schema.json",
  "title": "CitationSafetyReport",
  "type": "object",
  "required": [
    "version",
    "refs_bib_present",
    "citekeys",
    "findings"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "refs_bib_present": {
      "type": "boolean"
    },
    "citekeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_citekeys": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cite_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "external_notes_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "tier",
          "overridable",
          "message"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "tier": {
            "enum": [
              "hard_block",
              "flag_and_confirm",
              "style_advice",
              "safe"
            ]
          },
          "overridable": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
